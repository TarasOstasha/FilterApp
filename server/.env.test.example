# Copy this file to .env.test in the server/ directory before running QA tests.
# .env.test is gitignored — never commit real credentials.

# Required: Mocha setup.js forces NODE_ENV=test; keep this in sync.
NODE_ENV=test

# Explicit opt-in so tests never run against an unintended database.
ALLOW_TEST_DATABASE=true

# Optional: name of your production DB — setup refuses if DB_NAME matches this value.
# PRODUCTION_DB_NAME=your_production_database_name

# DB_NAME must contain this substring (default: _test). Override only if you use another convention.
# TEST_DB_NAME_MARKER=_test

# Dedicated PostgreSQL database for QA (create it separately, e.g. CREATE DATABASE filter_app_test;)
DB_USER=postgres
DB_PASSWORD=your_test_password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=filter_app_test

# Optional: if set, must point at the test database (name must include TEST_DB_NAME_MARKER).
# DATABASE_URL=postgres://postgres:your_test_password@127.0.0.1:5432/filter_app_test

# Used by Sequelize (models/index.js) and JWT middleware during tests
JWT_SECRET=test-jwt-secret-change-me

# Supertest does not bind a port; PORT is unused unless a test starts index.js explicitly.
PORT=5001

# Excel source-of-truth for qa-tests/api/productsFromExcel.test.js (row 1 = headers)
# QA_PRODUCTS_EXCEL_PATH=./path/to/your/products.xlsx
# QA_PRODUCTS_EXCEL_SHEET=Sheet1

# Or use the flat fixture profile (checkbox only — skips width/height/price):
# npm run test:api:flat
# npm run test:api:multi:flat
# Profile file: qa-tests/config/flat-checkbox.env

# Product price range (products.product_price from DB, not Excel filter tiers):
# npm run test:api:price:flat
# Profile file: qa-tests/config/flat-price.env

# Multi-filter checkbox combos + product price range:
# npm run test:api:multi-price:flat
# Profile file: qa-tests/config/flat-multi-price.env

# Display Width / Height range filters (point + span ranges):
# npm run test:api:dimensions:flat
# Profile file: qa-tests/config/flat-dimensions.env

# Full integration: checkboxes + width + height + product price:
# npm run test:api:full:flat
# Profile file: qa-tests/config/flat-full.env

# Skip specific fields in API tests (comma-separated canonical names):
# QA_EXCLUDE_TEST_FIELDS=Display_Width,Display_Height,Product_Price

# API tests load hide_product=Y from the test DB and exclude those codes from expected counts
# (matches GET /api/products visibility in productVisibility.js).

# Optional: cap unique values per filter (full Product_Price can be 5000+ cases)
# QA_MAX_UNIQUE_VALUES_PER_FILTER=25

# Optional: per-test timeout in ms (default 120000)
# QA_TEST_TIMEOUT_MS=120000
